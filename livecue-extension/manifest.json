{
  "manifest_version": 3,
  "name": "LiveCue Watch & Learn",
  "version": "1.0.0",
  "description": "Injects a lightweight Watch & Learn panel into TikTok LIVE pages.",
  "permissions": [
    "activeTab",
    "tabs",
    "storage",
    "tabCapture",
    "offscreen"
  ],
  "host_permissions": [
    "https://www.tiktok.com/*",
    "https://ark.cn-beijing.volces.com/*",
    "https://api.openai.com/*",
    "https://api.anthropic.com/*",
    "http://127.0.0.1/*",
    "http://localhost/*"
  ],
  "background": {
    "service_worker": "background/service-worker.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": [
        "https://www.tiktok.com/*"
      ],
      "js": [
        "content/tiktok-extractor.js",
        "content/livecue-content.js"
      ],
      "css": [
        "content/livecue-panel.css"
      ],
      "run_at": "document_idle"
    }
  ],
  "options_page": "options/options.html",
  "action": {
    "default_title": "LiveCue"
  },
  "web_accessible_resources": [
    {
      "resources": [
        "shared/sample-skill-insights.json"
      ],
      "matches": [
        "https://www.tiktok.com/*"
      ]
    }
  ]
}
